# ─── TELEGRAM ─────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Outsider Intel (broadcast channel — copy the ID, e.g. -1001234567890)
INTEL_CHANNEL_ID=your_intel_channel_id_here

# Outsider Community (supergroup — copy the ID, e.g. -1009876543210)
COMMUNITY_GROUP_ID=your_community_group_id_here

# ─── AI MODELS ────────────────────────────────────────────
# Claude (Anthropic) — console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# DeepSeek — platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_key_here

# Groq (free) — console.groq.com
GROQ_API_KEY=your_groq_key_here

# Google Gemini (free) — aistudio.google.com
GEMINI_API_KEY=your_gemini_key_here

# Cerebras (free) — cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_key_here

# OpenRouter (free models) — openrouter.ai
OPENROUTER_API_KEY=your_openrouter_key_here

# ─── DATA SOURCES ─────────────────────────────────────────
# CoinGecko — free tier, no key needed (or add Pro key for higher limits)
COINGECKO_API_KEY=

# Taostats API — taostats.io (optional, improves data quality)
TAOSTATS_API_KEY=

# ─── SETTINGS ─────────────────────────────────────────────
# Timezone for scheduled posts (default UTC)
TIMEZONE=UTC

# Daily brief time (24h format, UTC)
DAILY_BRIEF_HOUR=6
DAILY_BRIEF_MINUTE=0
