---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy Policy"
  description="Privacy policy for Tao Outsider and Outsider Intel services."
  canonicalURL="https://taooutsider.com/privacy/"
>
  <section class="legal container">
    <h1>Privacy Policy</h1>
    <p>Last updated: April 21, 2026</p>

    <h2>Information We Collect</h2>
    <p>We may collect contact details you share with us through Telegram, email, or direct communication channels.</p>

    <h2>How We Use Information</h2>
    <p>We use information to deliver requested updates, provide service support, and improve our research and communication workflow.</p>

    <h2>Data Sharing</h2>
    <p>We do not sell personal information. We may share operational data with service providers that help us run communication and analytics tools.</p>

    <h2>Data Retention</h2>
    <p>We keep information only as long as needed for service delivery, legal compliance, and security operations.</p>

    <h2>Contact</h2>
    <p>For privacy requests, contact us via <a href="https://t.me/taooutsider" rel="noopener">Telegram</a>.</p>
  </section>
</BaseLayout>

<style>
  .legal {
    max-width: 760px;
    padding: 56px 24px 80px;
  }
  .legal h1 {
    margin-bottom: 10px;
  }
  .legal h2 {
    margin-top: 28px;
    margin-bottom: 8px;
    font-size: 1.1rem;
  }
  .legal p {
    color: var(--text2);
    line-height: 1.7;
  }
</style>
