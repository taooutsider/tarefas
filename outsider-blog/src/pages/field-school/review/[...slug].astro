---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('blog'))
    .filter(post => post.data.draft && post.id.startsWith('bittensor-field-school-'));

  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props { post: CollectionEntry<'blog'>; }
const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, tags, author, image, imageAlt, ogImage } = post.data;
---

<BaseLayout
  title={`Review Draft | ${title}`}
  description={description}
  canonicalURL={`https://www.taooutsider.com/field-school/review/${post.id}/`}
  ogImage={ogImage ?? image}
  ogImageAlt={imageAlt ?? title}
  noindex={true}
>
  <article class="review-draft container">
    <header>
      <a href="/field-school/review/" class="back-link">Back to review queue</a>
      <p class="status">Draft review only</p>
      <h1>{title}</h1>
      <p class="description">{description}</p>
      <div class="meta">
        <span>{author}</span>
        <span>{pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
        <span>{tags.join(', ')}</span>
      </div>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<script is:inline>
  (() => {
    const quizBlocks = Array.from(document.querySelectorAll('[data-quiz]'));
    quizBlocks.forEach((quiz) => {
      const submit = quiz.querySelector('[data-quiz-submit]');
      const result = quiz.querySelector('[data-quiz-result]');
      const questions = Array.from(quiz.querySelectorAll('[data-answer]'));
      if (!submit || !result || questions.length === 0) return;

      submit.addEventListener('click', () => {
        let score = 0;
        let answered = 0;

        questions.forEach((question) => {
          const answer = question.dataset.answer;
          const selected = question.querySelector('input[type="radio"]:checked');
          question.classList.remove('is-correct', 'is-missed');

          if (!selected) return;
          answered += 1;

          if (selected.value === answer) {
            score += 1;
            question.classList.add('is-correct');
          } else {
            question.classList.add('is-missed');
          }
        });

        if (answered < questions.length) {
          result.textContent = 'Answer every question first.';
          result.dataset.state = 'warn';
          return;
        }

        result.textContent = `You scored ${score}/${questions.length}. ${score === questions.length ? 'Ready for the next module.' : 'Reread the missed section and try again.'}`;
        result.dataset.state = score === questions.length ? 'ok' : 'warn';
      });
    });
  })();
</script>

<style>
  .review-draft {
    max-width: 820px;
    padding: 54px 24px 90px;
  }
  .back-link {
    color: var(--muted);
    border-bottom: 1px solid var(--border2);
    font-size: 0.9rem;
  }
  .status {
    color: var(--muted);
    font-size: 12px;
    letter-spacing: 0.18em;
    margin: 28px 0 12px;
    text-transform: uppercase;
  }
  h1 {
    margin-bottom: 14px;
  }
  .description {
    color: var(--text2);
    font-size: 1.08rem;
    line-height: 1.65;
    max-width: 720px;
    margin-bottom: 16px;
  }
  .meta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    color: var(--muted);
    font-size: 0.86rem;
    margin-bottom: 38px;
  }
  .meta span + span::before {
    content: "/";
    margin-right: 8px;
    color: var(--border2);
  }
</style>
