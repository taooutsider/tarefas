---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

const allPosts = await getCollection('blog');
const sorted = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog | Bittensor Analysis, Subnet Deep Dives & TAO Intelligence"
  description="All Bittensor intelligence articles from Tao Outsider. Market analysis, subnet deep dives, dTAO alpha tokens, TAO trade setups and beginner guides."
  canonicalURL="https://www.taooutsider.com/blog/"
>
  <section class="page-header container">
    <h1>Zoomed out on TAO Bittensor.</h1>
    <p>Tracking every dTAO subnet. Mapping the future of decentralized AI.</p>
  </section>

  <section class="blog-listing container" aria-label="All posts">
    <nav class="cat-filter" aria-label="Filter by category">
      <a href="/blog/" class="cat-pill active">All</a>
      <a href="/blog/tag/analysis/" class="cat-pill">Analysis</a>
      <a href="/blog/tag/weekly/" class="cat-pill">Weekly</a>
      <a href="/blog/tag/news/" class="cat-pill">News</a>
    </nav>

    {sorted.length > 0 ? (
      <div class="posts-grid" role="list">
        {sorted.map(post => (
          <div role="listitem">
            <PostCard post={post} size="large" />
          </div>
        ))}
      </div>
    ) : (
      <p class="empty">No posts yet. Check back soon.</p>
    )}
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 64px 24px 32px;
    max-width: 860px;
    margin: 0 auto;
    text-align: center;
  }
  .page-header h1 {
    margin-bottom: 12px;
    font-size: clamp(2rem, 5vw, 3.4rem);
  }
  .page-header p {
    font-size: 1.15rem;
    color: var(--text2);
    max-width: 760px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .blog-listing { padding: 0 24px 80px; }
  .cat-filter {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 32px;
    max-width: 860px;
    margin-inline: auto;
    justify-content: center;
  }
  .cat-pill {
    font-size: 12px;
    font-weight: 500;
    padding: 5px 13px;
    border: 1px solid var(--border);
    border-radius: 20px;
    color: var(--muted);
    background: var(--s1);
    transition: all 0.12s;
  }
  .cat-pill:hover, .cat-pill.active {
    border-color: var(--border2);
    color: var(--text);
    background: var(--s2);
  }
  .posts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    max-width: 860px;
    margin: 0 auto;
  }
  .empty { font-size: 14px; color: var(--muted); }
  @media (max-width: 768px) {
    .page-header {
      max-width: 640px;
      padding: 40px 16px 24px;
      text-align: left;
    }
    .cat-filter {
      max-width: 640px;
      margin-bottom: 16px;
      justify-content: flex-start;
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: 2px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .cat-filter::-webkit-scrollbar { display: none; }
    .cat-pill { flex: 0 0 auto; }
    .posts-grid {
      grid-template-columns: 1fr;
      max-width: 640px;
      gap: 16px;
    }
  }
</style>
