---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

const allPosts = await getCollection('blog');
const sorted = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog — Bittensor Analysis, Subnet Deep Dives & TAO Intelligence"
  description="All Bittensor intelligence articles from Tao Outsider — market analysis, subnet deep dives, dTAO alpha tokens, TAO trade setups and beginner guides."
  canonicalURL="https://taooutsider.com/blog/"
>
  <section class="page-header container">
    <h1>Bittensor Intelligence</h1>
    <p>All articles — market analysis, subnet research, trade setups, and guides for serious TAO participants.</p>
  </section>

  <section class="blog-listing container" aria-label="All posts">
    <nav class="cat-filter" aria-label="Filter by category">
      <a href="/blog/" class="cat-pill active">All</a>
      <a href="/blog/tag/analysis/" class="cat-pill">Analysis</a>
      <a href="/blog/tag/subnet/" class="cat-pill">Subnets</a>
      <a href="/blog/tag/trade/" class="cat-pill">Trade Setups</a>
      <a href="/blog/tag/guide/" class="cat-pill">Guides</a>
      <a href="/blog/tag/weekly/" class="cat-pill">Weekly</a>
      <a href="/blog/tag/news/" class="cat-pill">News</a>
    </nav>

    {sorted.length > 0 ? (
      <div class="posts-grid" role="list">
        {sorted.map(post => (
          <div role="listitem">
            <PostCard post={post} />
          </div>
        ))}
      </div>
    ) : (
      <p class="empty">No posts yet — check back soon.</p>
    )}
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 56px 24px 40px;
    max-width: 640px;
  }
  .page-header h1 { margin-bottom: 10px; }
  .page-header p { font-size: 15px; color: var(--text2); }
  .blog-listing { padding: 0 24px 80px; }
  .cat-filter {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
  .cat-pill {
    font-size: 12px;
    font-weight: 500;
    padding: 5px 13px;
    border: 1px solid var(--border);
    border-radius: 20px;
    color: var(--muted);
    background: var(--s1);
    transition: all 0.12s;
  }
  .cat-pill:hover, .cat-pill.active {
    border-color: var(--border2);
    color: var(--text);
    background: var(--s2);
  }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .empty { font-size: 14px; color: var(--muted); }
  @media (max-width: 768px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .posts-grid { grid-template-columns: 1fr; } }
</style>
