---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EcosystemPulse from '../components/EcosystemPulse.astro';
import TaoFlowsPulse from '../components/TaoFlowsPulse.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = (await getCollection('blog')).filter(post => !post.data.draft);
const sorted = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = sorted.find(p => p.data.featured) ?? sorted[0];
const recent = sorted.filter(p => p !== featured).slice(0, 6);

const featuredDate = featured?.data.pubDate.toLocaleDateString('en-US', {
  month: 'short', day: 'numeric', year: 'numeric',
});

const categoryLabel: Record<string, string> = {
  analysis: 'Analysis', subnet: 'Subnet Deep Dive',
  trade: 'Trade Setup', guide: 'Guide',
};
---

<BaseLayout
  title="Tao Outsider"
  description="Zoomed out on TAO Bittensor. Tracking every dTAO subnet. Mapping the future of decentralized AI."
>
  <section class="site-subtitle-wrap container" aria-label="Blog subtitle">
    <p class="site-subtitle">Zoomed out on TAO Bittensor. Tracking every dTAO subnet. Mapping the future of decentralized AI.</p>
  </section>

  <!-- HERO -->
  <section class="hero container" aria-label="Featured article">
    <div class="hero-grid">

      {featured && (
        <article class="hero-featured" itemscope itemtype="https://schema.org/BlogPosting">
          <a href={`/blog/${featured.id}/`} class="hero-thumb" aria-label={featured.data.title}>
            <div class="hero-thumb-inner">
              {featured.data.image ? (
                <img src={featured.data.image} alt="" />
              ) : (
                <span class="thumb-label">FEATURED</span>
              )}
            </div>
          </a>
          <div class="hero-body">
            <span class:list={['tag', `tag-${featured.data.category}`]}>
              {categoryLabel[featured.data.category] ?? featured.data.category}
            </span>
            <h1 class="hero-title" itemprop="headline">
              <a href={`/blog/${featured.id}/`}>{featured.data.title}</a>
            </h1>
            <p class="hero-excerpt" itemprop="description">{featured.data.description}</p>
            <div class="hero-meta">
              <time datetime={featured.data.pubDate.toISOString()} itemprop="datePublished">
                {featuredDate}
              </time>
              {featured.data.tags.length > 0 && (
                <>
                  <span aria-hidden="true">·</span>
                  <span>{featured.data.tags.slice(0, 3).join(', ')}</span>
                </>
              )}
            </div>
          </div>
        </article>
      )}

      <!-- Sidebar -->
      <aside class="hero-sidebar" aria-label="Join the community">
        <div class="sidebar-trending">
          <h2 class="sidebar-heading">Trending</h2>
          <ol class="trending-list" role="list">
            {sorted.slice(0, 5).map((p, i) => (
              <li class="trending-item">
                <span class="t-num" aria-hidden="true">0{i + 1}</span>
                <div>
                  <a href={`/blog/${p.id}/`} class="t-title">{p.data.title}</a>
                  <div class="t-meta">
                    <time datetime={p.data.pubDate.toISOString()}>
                      {p.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                    </time>
                  </div>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </aside>

    </div>
  </section>

  <EcosystemPulse />
  <TaoFlowsPulse />

  <hr class="divider" />

  {recent.length > 0 && (
    <section class="recent container" aria-labelledby="recent-heading">
      <div class="section-header">
        <h2 id="recent-heading">Latest Intelligence</h2>
        <a href="/blog/">View all &rarr;</a>
      </div>

      <!-- Category filter (static links, SEO-friendly) -->
      <nav class="cat-filter" aria-label="Filter by category">
        <a href="/blog/" class="cat-pill active">All</a>
        <a href="/blog/tag/analysis/" class="cat-pill">Analysis</a>
      </nav>

      <div class="posts-grid" role="list">
        {recent.map(post => (
          <div role="listitem">
            <PostCard post={post} />
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- NEWSLETTER -->
  <section class="newsletter container" aria-labelledby="nl-heading">
    <div class="nl-inner">
      <h2 id="nl-heading">Free weekly Bittensor brief</h2>
      <p>The most important TAO developments every week, market moves, subnet changes, new alpha. No spam.</p>
      <form class="nl-form" method="POST" action="/api/subscribe">
        <label for="nl-email" class="sr-only">Email address</label>
        <input type="email" id="nl-email" name="email" placeholder="your@email.com" required autocomplete="email" />
        <button type="submit">Subscribe &rarr;</button>
      </form>
    </div>
  </section>

</BaseLayout>

<style>
  /* HERO */
  .site-subtitle-wrap {
    padding: 28px 24px 0;
  }
  .site-subtitle {
    color: var(--text2);
    font-size: 14px;
    line-height: 1.65;
    max-width: 760px;
  }
  .hero { padding: 56px 24px 48px; }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 32px;
    align-items: start;
  }
  .hero-featured {
    background: var(--s1);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }
  .hero-thumb {
    display: block;
    height: 280px;
    background: var(--s2);
    position: relative;
    overflow: hidden;
  }
  .hero-thumb::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(0deg, transparent, transparent 36px, var(--border) 36px, var(--border) 37px),
      repeating-linear-gradient(90deg, transparent, transparent 36px, var(--border) 36px, var(--border) 37px);
    opacity: 0.5;
  }
  .hero-thumb-inner {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-thumb-inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    position: relative;
    z-index: 1;
  }
  .hero-thumb:has(img)::before {
    display: none;
  }
  .thumb-label {
    font-size: 10px;
    letter-spacing: 0.25em;
    font-weight: 700;
    color: var(--muted);
    font-family: var(--mono, monospace);
  }
  .hero-body { padding: 28px; }
  .hero-body .tag { margin-bottom: 12px; }
  .hero-title {
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    margin-bottom: 12px;
    letter-spacing: -0.03em;
  }
  .hero-title a { color: var(--white); }
  .hero-title a:hover { color: var(--text2); }
  .hero-excerpt { font-size: 15px; color: var(--text2); line-height: 1.7; margin-bottom: 16px; }
  .hero-meta { font-size: 13px; color: var(--muted); display: flex; gap: 8px; flex-wrap: wrap; }

  /* SIDEBAR */
  .hero-sidebar { display: flex; flex-direction: column; gap: 20px; }
  .sidebar-trending {
    background: var(--s1);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
  }
  .sidebar-heading {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 16px;
  }
  .trending-list { list-style: none; }
  .trending-item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }
  .trending-item:last-child { border-bottom: none; padding-bottom: 0; }
  .t-num {
    font-size: 18px;
    font-weight: 900;
    color: var(--border2);
    min-width: 24px;
    line-height: 1;
    font-family: var(--mono, monospace);
    margin-top: 1px;
  }
  .t-title {
    font-size: 13.5px;
    font-weight: 500;
    color: var(--text);
    line-height: 1.45;
    display: block;
    margin-bottom: 3px;
    transition: color 0.12s;
  }
  .t-title:hover { color: var(--white); }
  .t-meta { font-size: 11px; color: var(--muted); }
  /* RECENT */
  .recent { padding: 48px 24px; }
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
    max-width: 980px;
    margin-inline: auto;
  }
  .section-header h2 { font-size: 1.1rem; }
  .section-header a { font-size: 13px; color: var(--text2); transition: color 0.12s; }
  .section-header a:hover { color: var(--white); }
  .cat-filter {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 28px;
    max-width: 980px;
    margin-inline: auto;
  }
  .cat-pill {
    font-size: 12px;
    font-weight: 500;
    padding: 5px 13px;
    border: 1px solid var(--border);
    border-radius: 20px;
    color: var(--muted);
    background: var(--s1);
    transition: all 0.12s;
  }
  .cat-pill:hover, .cat-pill.active {
    border-color: var(--border2);
    color: var(--text);
    background: var(--s2);
  }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px;
    max-width: 980px;
    margin: 0 auto;
  }
  .empty { color: var(--muted); font-size: 14px; }

  /* NEWSLETTER */
  .newsletter { padding: 0 24px 80px; }
  .nl-inner {
    background: var(--s1);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 48px;
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }
  .nl-inner h2 { font-size: 1.4rem; margin-bottom: 10px; }
  .nl-inner p { font-size: 14px; color: var(--text2); margin-bottom: 28px; }
  .nl-form { display: flex; gap: 10px; max-width: 400px; margin: 0 auto; }
  .nl-form input {
    flex: 1;
    background: var(--bg);
    border: 1px solid var(--border2);
    color: var(--text);
    padding: 10px 14px;
    border-radius: 7px;
    font-size: 14px;
    outline: none;
    font-family: var(--font);
  }
  .nl-form input:focus { border-color: var(--border2); box-shadow: 0 0 0 2px rgba(255,255,255,0.08); }
  .nl-form button {
    background: var(--white);
    color: #000;
    border: none;
    font-weight: 700;
    font-size: 13px;
    padding: 10px 18px;
    border-radius: 7px;
    cursor: pointer;
    font-family: var(--font);
    white-space: nowrap;
    transition: opacity 0.12s;
  }
  .nl-form button:hover { opacity: 0.85; }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-sidebar { display: none; }
  }
  @media (max-width: 640px) {
    .site-subtitle-wrap { padding: 20px 16px 0; }
    .hero { padding: 32px 16px 24px; }
    .hero-thumb { height: 180px; }
    .section-header {
      max-width: 680px;
      margin-bottom: 16px;
    }
    .cat-filter {
      max-width: 680px;
      margin-bottom: 20px;
    }
    .posts-grid {
      grid-template-columns: 1fr;
      max-width: 680px;
      gap: 16px;
    }
    .nl-form { flex-direction: column; }
  }
</style>
