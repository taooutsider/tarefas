<section class="ecosystem-pulse container" aria-labelledby="ecosystem-pulse-heading" data-ecosystem-pulse>
  <div class="pulse-header">
    <div>
      <p class="pulse-kicker">Bittensor data layer</p>
      <h2 id="ecosystem-pulse-heading">Ecosystem Pulse</h2>
    </div>
    <a href="https://taoswap.org/explore/subnets/" target="_blank" rel="noopener">Open TaoSwap</a>
  </div>

  <div class="pulse-overview" aria-label="Bittensor network overview">
    <div class="metric-card">
      <span>Total subnets</span>
      <strong data-pulse-metric="totalSubnets">...</strong>
    </div>
    <div class="metric-card">
      <span>Subnet market cap</span>
      <strong data-pulse-metric="totalMarketCapTao">...</strong>
    </div>
    <div class="metric-card">
      <span>Emitting subnets</span>
      <strong data-pulse-metric="emittingSubnets">...</strong>
    </div>
    <div class="metric-card">
      <span>Active miners</span>
      <strong data-pulse-metric="totalActiveMiners">...</strong>
    </div>
  </div>

  <div class="pulse-grid">
    <section class="pulse-panel" aria-labelledby="movers-heading">
      <div class="panel-head">
        <h3 id="movers-heading">24h Movers</h3>
        <span data-pulse-updated>Loading</span>
      </div>
      <div class="rank-columns">
        <div>
          <p class="rank-title">Strength</p>
          <ol class="rank-list" data-pulse-list="topGainers24h"></ol>
        </div>
        <div>
          <p class="rank-title">Weakness</p>
          <ol class="rank-list" data-pulse-list="topLosers24h"></ol>
        </div>
      </div>
    </section>

    <section class="pulse-panel" aria-labelledby="flow-heading">
      <div class="panel-head">
        <h3 id="flow-heading">Flow Watch</h3>
        <span data-pulse-net-flow>...</span>
      </div>
      <div class="rank-columns">
        <div>
          <p class="rank-title">Inflow</p>
          <ol class="rank-list" data-pulse-list="topInflows"></ol>
        </div>
        <div>
          <p class="rank-title">Outflow</p>
          <ol class="rank-list" data-pulse-list="topOutflows"></ol>
        </div>
      </div>
    </section>

    <section class="pulse-panel pulse-panel-wide" aria-labelledby="heatmap-heading">
      <div class="panel-head">
        <h3 id="heatmap-heading">Subnet Heatmap</h3>
        <span>Top market caps</span>
      </div>
      <div class="subnet-heatmap" data-pulse-heatmap aria-label="Subnet heatmap"></div>
    </section>

    <section class="pulse-panel" aria-labelledby="largest-heading">
      <div class="panel-head">
        <h3 id="largest-heading">Largest Subnets</h3>
        <span>Market cap</span>
      </div>
      <ol class="rank-list" data-pulse-list="topMarketCaps"></ol>
    </section>

    <section class="pulse-panel" aria-labelledby="validators-heading">
      <div class="panel-head">
        <h3 id="validators-heading">Validator Watch</h3>
        <span>Stake</span>
      </div>
      <ol class="rank-list" data-pulse-list="topValidators"></ol>
    </section>
  </div>

  <p class="pulse-status" data-pulse-status aria-live="polite"></p>
</section>

<script>
  const roots = document.querySelectorAll('[data-ecosystem-pulse]');

  const compactNumber = (value, maximumFractionDigits = 1) => {
    const number = Number(value);
    if (!Number.isFinite(number)) return 'Unavailable';
    return number.toLocaleString('en-US', {
      notation: 'compact',
      maximumFractionDigits,
    });
  };

  const formatTao = (value, maximumFractionDigits = 1) => `${compactNumber(value, maximumFractionDigits)} TAO`;

  const formatChange = (value) => {
    const number = Number(value);
    if (!Number.isFinite(number)) return 'Unavailable';
    if (number > 0) return `${number.toFixed(2)}% up`;
    if (number < 0) return `${Math.abs(number).toFixed(2)}% down`;
    return 'Flat';
  };

  const formatTime = (value) => {
    const date = new Date(value);
    if (Number.isNaN(date.valueOf())) return '';
    return `Updated ${date.toLocaleTimeString('en-US', {
      hour: '2-digit',
      minute: '2-digit',
    })}`;
  };

  const subnetLabel = (item) => `SN${item.id} ${item.name}`;

  const renderSubnetList = (list, items, formatter) => {
    list.innerHTML = '';
    items.forEach((item) => {
      const li = document.createElement('li');
      const left = document.createElement('span');
      const right = document.createElement('strong');
      left.textContent = subnetLabel(item);
      right.textContent = formatter(item);
      li.append(left, right);
      list.append(li);
    });
  };

  const renderValidatorList = (list, items) => {
    list.innerHTML = '';
    items.forEach((item) => {
      const li = document.createElement('li');
      const left = document.createElement('span');
      const right = document.createElement('strong');
      left.textContent = item.name;
      right.textContent = formatTao(item.totalStake, 1);
      li.append(left, right);
      list.append(li);
    });
  };

  const renderHeatmap = (root, items) => {
    const heatmap = root.querySelector('[data-pulse-heatmap]');
    if (!heatmap) return;
    heatmap.innerHTML = '';
    items.forEach((item) => {
      const dot = document.createElement('a');
      dot.href = `https://taoswap.org/explore/subnets/${item.id}`;
      dot.target = '_blank';
      dot.rel = 'noopener';
      dot.title = `${subnetLabel(item)} ${formatChange(item.change24h)}`;
      dot.setAttribute('aria-label', dot.title);
      dot.className = Number(item.change24h) >= 0 ? 'heatmap-dot is-positive' : 'heatmap-dot is-negative';
      dot.textContent = String(item.id);
      heatmap.append(dot);
    });
  };

  const hydratePulse = async (root) => {
    const status = root.querySelector('[data-pulse-status]');
    try {
      const response = await fetch('/api/ecosystem-pulse');
      if (!response.ok) throw new Error('Pulse request failed.');
      const data = await response.json();
      const overview = data.overview || {};

      root.querySelector('[data-pulse-metric="totalSubnets"]').textContent = compactNumber(overview.totalSubnets, 0);
      root.querySelector('[data-pulse-metric="totalMarketCapTao"]').textContent = formatTao(overview.totalMarketCapTao, 1);
      root.querySelector('[data-pulse-metric="emittingSubnets"]').textContent = compactNumber(overview.emittingSubnets, 0);
      root.querySelector('[data-pulse-metric="totalActiveMiners"]').textContent = compactNumber(overview.totalActiveMiners, 0);

      const updated = root.querySelector('[data-pulse-updated]');
      if (updated) updated.textContent = formatTime(data.updatedAt);

      const netFlow = root.querySelector('[data-pulse-net-flow]');
      if (netFlow) {
        const value = Number(overview.netFlowTao);
        netFlow.textContent = value >= 0 ? `${formatTao(value, 2)} net inflow` : `${formatTao(Math.abs(value), 2)} net outflow`;
      }

      renderSubnetList(root.querySelector('[data-pulse-list="topGainers24h"]'), data.subnets?.topGainers24h || [], (item) => formatChange(item.change24h));
      renderSubnetList(root.querySelector('[data-pulse-list="topLosers24h"]'), data.subnets?.topLosers24h || [], (item) => formatChange(item.change24h));
      renderSubnetList(root.querySelector('[data-pulse-list="topInflows"]'), data.subnets?.topInflows || [], (item) => formatTao(item.inflow, 2));
      renderSubnetList(root.querySelector('[data-pulse-list="topOutflows"]'), data.subnets?.topOutflows || [], (item) => formatTao(item.outflow, 2));
      renderSubnetList(root.querySelector('[data-pulse-list="topMarketCaps"]'), data.subnets?.topMarketCaps || [], (item) => formatTao(item.marketCapTao, 1));
      renderValidatorList(root.querySelector('[data-pulse-list="topValidators"]'), data.validators?.topStake || []);
      renderHeatmap(root, data.subnets?.heatmap || []);

      if (status) status.textContent = `Data source ${data.source}`;
      root.classList.add('is-loaded');
    } catch {
      if (status) status.textContent = 'Ecosystem pulse is unavailable right now.';
      root.classList.add('is-muted');
    }
  };

  roots.forEach(hydratePulse);
</script>

<style>
  .ecosystem-pulse {
    padding: 18px 24px 56px;
  }
  .pulse-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 18px;
  }
  .pulse-kicker {
    color: var(--muted);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 5px;
  }
  .pulse-header h2 {
    font-size: clamp(1.45rem, 3vw, 2rem);
    letter-spacing: 0;
  }
  .pulse-header a {
    color: var(--text2);
    font-size: 13px;
    font-weight: 700;
    white-space: nowrap;
  }
  .pulse-header a:hover {
    color: var(--white);
  }
  .pulse-overview {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-bottom: 14px;
  }
  .metric-card,
  .pulse-panel {
    background: var(--s1);
    border: 1px solid var(--border);
    border-radius: 8px;
  }
  .metric-card {
    display: grid;
    gap: 8px;
    min-height: 92px;
    padding: 16px;
  }
  .metric-card span,
  .panel-head span,
  .rank-title,
  .pulse-status {
    color: var(--muted);
    font-size: 11px;
  }
  .metric-card strong {
    color: var(--white);
    font-size: clamp(1.25rem, 2.4vw, 1.75rem);
    line-height: 1.1;
  }
  .pulse-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }
  .pulse-panel {
    padding: 18px;
    min-width: 0;
  }
  .pulse-panel-wide {
    grid-column: 1 / -1;
  }
  .panel-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
  }
  .panel-head h3 {
    font-size: 1rem;
    letter-spacing: 0;
  }
  .panel-head span {
    text-align: right;
  }
  .rank-columns {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }
  .rank-title {
    margin-bottom: 8px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .rank-list {
    display: grid;
    gap: 8px;
    list-style: none;
  }
  .rank-list li {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: baseline;
    gap: 10px;
    min-height: 22px;
    color: var(--text2);
    font-size: 13px;
  }
  .rank-list span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .rank-list strong {
    color: var(--text);
    font-size: 12px;
    white-space: nowrap;
  }
  .subnet-heatmap {
    display: grid;
    grid-template-columns: repeat(24, minmax(0, 1fr));
    gap: 5px;
  }
  .heatmap-dot {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1;
    min-width: 0;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--s2);
    color: var(--muted);
    font-family: var(--mono);
    font-size: 9px;
    line-height: 1;
    transition: color 0.12s, border-color 0.12s, background 0.12s;
  }
  .heatmap-dot.is-positive {
    color: var(--text);
    border-color: #ffffff33;
    background: #151515;
  }
  .heatmap-dot.is-negative {
    color: var(--muted);
    background: #080808;
  }
  .heatmap-dot:hover {
    border-color: var(--white);
    color: var(--white);
  }
  .pulse-status {
    margin-top: 12px;
  }
  .ecosystem-pulse.is-muted {
    opacity: 0.75;
  }

  @media (max-width: 900px) {
    .pulse-overview {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .pulse-grid {
      grid-template-columns: 1fr;
    }
    .subnet-heatmap {
      grid-template-columns: repeat(12, minmax(0, 1fr));
    }
  }
  @media (max-width: 640px) {
    .ecosystem-pulse {
      padding: 18px 16px 40px;
    }
    .pulse-header {
      align-items: start;
      flex-direction: column;
      gap: 10px;
    }
    .pulse-overview {
      gap: 10px;
    }
    .metric-card {
      min-height: 84px;
      padding: 14px;
    }
    .rank-columns {
      grid-template-columns: 1fr;
      gap: 14px;
    }
    .subnet-heatmap {
      grid-template-columns: repeat(8, minmax(0, 1fr));
    }
  }
</style>
