<section class="taoswap-pulse container" aria-labelledby="taoswap-pulse-heading" data-taoswap-pulse>
  <div class="pulse-head">
    <div>
      <p class="pulse-kicker">TaoSwap signal</p>
      <h2 id="taoswap-pulse-heading">Subnet market pulse</h2>
    </div>
    <a href="https://taoswap.org/explore/subnets/" target="_blank" rel="noopener">Open TaoSwap</a>
  </div>

  <div class="pulse-card" aria-label="TaoSwap subnet market highlights">
    <article class="signal-item">
      <span>24h strength</span>
      <strong data-pulse="strengthName">Loading</strong>
      <small data-pulse="strengthValue">...</small>
    </article>

    <article class="signal-item">
      <span>Capital leader</span>
      <strong data-pulse="capitalName">Loading</strong>
      <small data-pulse="capitalValue">...</small>
    </article>

    <article class="signal-item">
      <span>Flow leader</span>
      <strong data-pulse="flowName">Loading</strong>
      <small data-pulse="flowValue">...</small>
    </article>
  </div>

  <p class="pulse-context" data-pulse="context" aria-live="polite">Reading TaoSwap data.</p>
</section>

<script>
  const roots = document.querySelectorAll('[data-taoswap-pulse]');

  const compactNumber = (value, maximumFractionDigits = 1) => {
    const number = Number(value);
    if (!Number.isFinite(number)) return 'Unavailable';
    return number.toLocaleString('en-US', {
      notation: 'compact',
      maximumFractionDigits,
    });
  };

  const formatTao = (value, maximumFractionDigits = 1) => `${compactNumber(value, maximumFractionDigits)} TAO`;

  const formatChange = (value) => {
    const number = Number(value);
    if (!Number.isFinite(number)) return 'Unavailable';
    if (number > 0) return `${number.toFixed(2)}% up`;
    if (number < 0) return `${Math.abs(number).toFixed(2)}% down`;
    return 'Flat';
  };

  const subnetLabel = (item) => item ? `SN${item.id} ${item.name}` : 'Unavailable';

  const setText = (root, key, value) => {
    const element = root.querySelector(`[data-pulse="${key}"]`);
    if (element) element.textContent = value;
  };

  const hydratePulse = async (root) => {
    try {
      const response = await fetch('/api/ecosystem-pulse');
      if (!response.ok) throw new Error('Pulse request failed.');

      const data = await response.json();
      const overview = data.overview || {};
      const strength = data.subnets?.topGainers24h?.[0];
      const capital = data.subnets?.topMarketCaps?.[0];
      const flow = data.subnets?.topInflows?.[0];

      setText(root, 'strengthName', subnetLabel(strength));
      setText(root, 'strengthValue', formatChange(strength?.change24h));
      setText(root, 'capitalName', subnetLabel(capital));
      setText(root, 'capitalValue', formatTao(capital?.marketCapTao, 1));
      setText(root, 'flowName', subnetLabel(flow));
      setText(root, 'flowValue', formatTao(flow?.inflow, 2));
      setText(
        root,
        'context',
        `${compactNumber(overview.totalSubnets, 0)} subnets tracked. ${compactNumber(overview.emittingSubnets, 0)} emitting. Data source ${data.source}.`,
      );

      root.classList.add('is-loaded');
    } catch {
      setText(root, 'context', 'TaoSwap pulse is unavailable right now.');
      root.classList.add('is-muted');
    }
  };

  roots.forEach(hydratePulse);
</script>

<style>
  .taoswap-pulse {
    padding: 0 24px 48px;
    max-width: 980px;
  }
  .pulse-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 14px;
  }
  .pulse-kicker {
    color: var(--muted);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .pulse-head h2 {
    font-size: 1.1rem;
    letter-spacing: 0;
  }
  .pulse-head a {
    color: var(--text2);
    font-size: 13px;
    font-weight: 700;
    white-space: nowrap;
    transition: color 0.12s;
  }
  .pulse-head a:hover {
    color: var(--white);
  }
  .pulse-card {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    background: var(--s1);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }
  .signal-item {
    min-width: 0;
    padding: 18px;
    border-right: 1px solid var(--border);
  }
  .signal-item:last-child {
    border-right: none;
  }
  .signal-item span {
    display: block;
    color: var(--muted);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .signal-item strong {
    display: block;
    color: var(--white);
    font-size: clamp(1rem, 2vw, 1.18rem);
    line-height: 1.35;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .signal-item small {
    display: block;
    color: var(--text2);
    font-size: 13px;
    margin-top: 5px;
  }
  .pulse-context {
    color: var(--muted);
    font-size: 12px;
    margin-top: 10px;
  }
  .taoswap-pulse.is-muted {
    opacity: 0.72;
  }
  @media (max-width: 720px) {
    .taoswap-pulse {
      padding: 0 16px 40px;
    }
    .pulse-head {
      align-items: flex-start;
    }
    .pulse-card {
      grid-template-columns: 1fr;
    }
    .signal-item {
      border-right: none;
      border-bottom: 1px solid var(--border);
      padding: 16px;
    }
    .signal-item:last-child {
      border-bottom: none;
    }
  }
</style>
