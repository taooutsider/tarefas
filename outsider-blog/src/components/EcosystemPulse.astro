<section class="taoswap-pulse container" aria-labelledby="taoswap-pulse-heading" data-taoswap-pulse>
  <div class="pulse-head">
    <div>
      <p class="pulse-kicker">TaoSwap signal</p>
      <h2 id="taoswap-pulse-heading">Subnet market pulse</h2>
    </div>
    <a class="pulse-button" href="https://taoswap.org/explore/subnets/" target="_blank" rel="noopener">Open TaoSwap &rarr;</a>
  </div>

  <div class="pulse-card" aria-label="TaoSwap subnet market highlights">
    <article class="leader-card">
      <span>24h top gainer</span>
      <strong data-pulse="gainerName">Loading</strong>
      <small data-pulse="gainerValue">...</small>
    </article>

    <section class="market-cap-card" aria-labelledby="top-market-cap-heading">
      <div class="list-head">
        <h3 id="top-market-cap-heading">Top 5 subnets</h3>
        <span>By market cap</span>
      </div>
      <ol class="market-cap-list" data-pulse-list="topMarketCaps">
        <li><span>Loading</span><strong>...</strong></li>
      </ol>
    </section>
  </div>

  <p class="pulse-context" data-pulse="context" aria-live="polite">Reading TaoSwap data.</p>
</section>

<script>
  const roots = document.querySelectorAll('[data-taoswap-pulse]');

  const compactNumber = (value, maximumFractionDigits = 1) => {
    const number = Number(value);
    if (!Number.isFinite(number)) return 'Unavailable';
    return number.toLocaleString('en-US', {
      notation: 'compact',
      maximumFractionDigits,
    });
  };

  const formatTao = (value, maximumFractionDigits = 1) => `${compactNumber(value, maximumFractionDigits)} TAO`;

  const formatChange = (value) => {
    const number = Number(value);
    if (!Number.isFinite(number)) return 'Unavailable';
    if (number > 0) return `${number.toFixed(2)}% up`;
    if (number < 0) return `${Math.abs(number).toFixed(2)}% down`;
    return 'Flat';
  };

  const subnetLabel = (item) => item ? `SN${item.id} ${item.name}` : 'Unavailable';

  const setText = (root, key, value) => {
    const element = root.querySelector(`[data-pulse="${key}"]`);
    if (element) element.textContent = value;
  };

  const renderMarketCaps = (root, items) => {
    const list = root.querySelector('[data-pulse-list="topMarketCaps"]');
    if (!list) return;
    list.innerHTML = '';
    items.slice(0, 5).forEach((item) => {
      const li = document.createElement('li');
      const name = document.createElement('span');
      const value = document.createElement('strong');
      name.textContent = subnetLabel(item);
      value.textContent = formatTao(item.marketCapTao, 1);
      li.append(name, value);
      list.append(li);
    });
  };

  const hydratePulse = async (root) => {
    try {
      const response = await fetch('/api/ecosystem-pulse');
      if (!response.ok) throw new Error('Pulse request failed.');

      const data = await response.json();
      const overview = data.overview || {};
      const gainer = data.subnets?.topGainers24h?.[0];
      const marketCaps = data.subnets?.topMarketCaps || [];

      setText(root, 'gainerName', subnetLabel(gainer));
      setText(root, 'gainerValue', formatChange(gainer?.change24h));
      renderMarketCaps(root, marketCaps);
      setText(
        root,
        'context',
        `${compactNumber(overview.totalSubnets, 0)} subnets tracked. Data source ${data.source}.`,
      );

      root.classList.add('is-loaded');
    } catch {
      setText(root, 'context', 'TaoSwap pulse is unavailable right now.');
      root.classList.add('is-muted');
    }
  };

  roots.forEach(hydratePulse);
</script>

